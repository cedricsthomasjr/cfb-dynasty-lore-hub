# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cfb_lore_hub?schema=public"

# ─── Storage (Phase 1: local disk) ──────────────────────────
# Where original screenshot bytes are written in dev.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
# Publicly served preview dir (under /public).
UPLOAD_PUBLIC_DIR="./public/uploads"
# Max upload size in bytes (10 MB).
MAX_UPLOAD_BYTES="10485760"

# ─── AI Vision (Phase 2 ingestion pipeline) ─────────────────
# Provider for screen detection + parsing.
#   "mock"      -> deterministic fixtures, no API key needed (dev/CI/tests)
#   "anthropic" -> real Claude vision (requires ANTHROPIC_API_KEY)
#   unset       -> anthropic if ANTHROPIC_API_KEY is set, else mock
VISION_DRIVER="mock"
# ANTHROPIC_API_KEY=""
# VISION_MODEL="claude-opus-4-8"

# ─── Stub auth (Phase 2.5) ──────────────────────────────────
# No auth provider yet: getCurrentUser() resolves a single dev user.
#   DEV_USER_ID    -> use this exact User id (must already exist)
#   DEV_USER_EMAIL -> upsert-by-email fallback (default "dev@localhost")
# DEV_USER_ID=""
DEV_USER_EMAIL="dev@localhost"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Gridiron Lore"
